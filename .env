# Benchmark configuration. Scripts load this with `set -a; . .env; set +a`.

NAMESPACE=carma            # Kubernetes namespace for the Ballista pods
SCHEDULER_PORT=50050       # scheduler gRPC/Flight + REST port
IMAGE_TAG=carma            # tag for the locally-built scheduler/executor images

# Node roles, derived from the cluster (single source of truth = the
# control-plane label, the same one the executor DaemonSet selects on).
# Override by exporting CONTROL_NODE / WORKER_NODES before running a script.
CONTROL_NODE="${CONTROL_NODE:-$(kubectl get nodes -l node-role.kubernetes.io/control-plane -o custom-columns=:.metadata.name --no-headers 2>/dev/null | head -1)}"   # scheduler + driver host
WORKER_NODES="${WORKER_NODES:-$(kubectl get nodes -l '!node-role.kubernetes.io/control-plane' -o custom-columns=:.metadata.name --no-headers 2>/dev/null | tr '\n' ' ')}"  # executor + dataset hosts

ROOT=/storage/carma                    # base dir on each node's local disk
DATA_DIR=${ROOT}/imdb                  # IMDb Parquet tables (hostPath, every node)
WORK_DIR=${ROOT}/work                  # executor scratch dir
WORKLOAD_CSV=${ROOT}/workload/workload.csv  # Redbench workload replayed by run.sh
RUNS_DIR=${ROOT}/runs                  # per-run output folders
# Uniform executor task slots. Nodes are heterogeneous (some 32-core, some
# 40-core); pinning --concurrent-tasks makes every executor identical so the
# cluster has a well-defined cores_per_executor. Keep <= the smallest node.
TASK_SLOTS=32
TRACE_DIR=${ROOT}/trace                # full per-stage CARMA trace (kind:"stage_trace"); the scheduler
                                       # appends here via BALLISTA_STAGE_TRACE_FILE and run.sh slices
                                       # each run's portion into <run>/stages.jsonl for carma-all.

# Cluster shape + pricing recorded into each run's cluster.json (feeds carma's
# ClusterHardware / PricingConfig so trace_replay stops assuming a reference cluster).
# num_executors / cores / memory are AUTO-MEASURED by run.sh from the live cluster;
# the values below are the thesis-modeled knobs the measurement can't observe.
CACHE_BYTES_PER_EXECUTOR=1099511627776   # 1 TiB — per-executor cache budget under study
INTRA_CLUSTER_BANDWIDTH_BPS=10000000000  # 10 Gb/s intra-cluster link
PRICE_VCPU_HOUR=0.048                    # $/vCPU-hour (statically provisioned)
PRICE_GB_TRANSFERRED=0.0                 # $/GB cross-node transfer (0 intra-AZ; ~0.01 cross-AZ)

# Ballista fork (built by build.sh; cloned automatically if missing).
BALLISTA_REPO=https://github.com/Rechenmaschine/datafusion-ballista   # fork to build
BALLISTA_REF=carma-listener                                          # branch/tag/commit
BALLISTA_SRC=${ROOT}/src/datafusion-ballista                         # local checkout path

IMDB_URL=https://event.cwi.nl/da/job/imdb.tgz   # IMDb/JOB CSV dump (downloaded by stage-data.sh)

# Redbench workload generation (gen-workload.sh; skip if a workload.csv already exists).
REDBENCH_REPO=https://github.com/DataManagementLab/Redbench       # Redbench source
REDBENCH_REF=a1298903fb6d6639862b139856993e5e748f2599             # pinned commit (reproducible)
REDSET_DATASET=provisioned                                        # Redset trace: provisioned | serverless
REDSET_URL=s3://redshift-downloads/redset/provisioned/full.parquet  # trace to download (~18 GB)
INSTANCE_ID=103            # Redset cluster id to mimic
DATABASE_ID=0              # Redset database id to mimic
GEN_STRATEGY=matching      # generation strategy: matching | generation
